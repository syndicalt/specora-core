# =============================================================================
# Specora Core — Environment Configuration
# =============================================================================
#
# Copy this file to .env and fill in your values.
#
# The Forge (compiler + generators) works without any API keys.
# The Factory, Healer (Tier 2-3), Extractor, and Chat require at least
# one AI provider to be configured.
#
# =============================================================================


# =============================================================================
# AI / LLM Providers
# =============================================================================
# At least one provider is required for LLM-powered features.
# Specora auto-detects the provider from whichever key is set.
# Priority: SPECORA_AI_MODEL > ANTHROPIC > OPENAI > XAI > OLLAMA

# --- Model Override (optional) ---
# Force a specific model instead of auto-detection.
# Examples: claude-sonnet-4-6, claude-opus-4-6, gpt-4o, gpt-4o-mini
# Full list: see engine/registry.py
SPECORA_AI_MODEL=

# --- Anthropic (recommended) ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- OpenAI ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- xAI (Grok) ---
# https://console.x.ai/
# Uses OpenAI-compatible API at https://api.x.ai/v1
XAI_API_KEY=

# --- Google Gemini ---
# https://aistudio.google.com/apikey
# Uses OpenAI-compatible API
GOOGLE_API_KEY=

# --- Z.AI (GLM) ---
# https://z.ai — sign up and get key from profile > API Keys
# Free models: glm-4.7-flash, glm-4.5-flash
# Paid models: glm-5.1, glm-5
# OpenAI-compatible at https://api.z.ai/api/paas/v4/
ZAI_API_KEY=

# --- Local Models (Ollama) ---
# Install: https://ollama.com/
# Pull: ollama pull llama3.3:70b
OLLAMA_BASE_URL=

# --- Local Models (LM Studio) ---
# https://lmstudio.ai/
LMSTUDIO_BASE_URL=


# =============================================================================
# Generated App — Database
# =============================================================================
# These apply to the generated runtime app (not specora-core itself).

# Postgres connection string
DATABASE_URL=postgresql://specora:specora@localhost:5432/specora

# Backend selection: postgres | memory
# memory = in-memory dict store (dev/demo, no persistence)
# postgres = asyncpg connection pool (production)
DATABASE_BACKEND=postgres


# =============================================================================
# Generated App — Server
# =============================================================================

# Port the generated FastAPI app listens on
PORT=8000

# Comma-separated CORS origins (* = allow all)
CORS_ORIGINS=*


# =============================================================================
# Generated App — Authentication
# =============================================================================
# Auth is only generated if the domain includes an infra/auth contract.

# Enable/disable auth middleware (true | false)
AUTH_ENABLED=false

# Auth provider: jwt | external
AUTH_PROVIDER=jwt

# JWT signing secret (CHANGE THIS IN PRODUCTION)
AUTH_SECRET=change-me-in-production

# JWT token expiration in minutes
AUTH_TOKEN_EXPIRE_MINUTES=60


# =============================================================================
# Healer Service
# =============================================================================

# Port for the Healer HTTP API (spc healer serve)
SPECORA_HEALER_PORT=8083

# Webhook URL for healer notifications (optional)
# Posts JSON {ticket_id, status, contract_fqn, explanation} on state changes
SPECORA_HEALER_WEBHOOK_URL=


# =============================================================================
# Editor
# =============================================================================
# Used by `factory new` to open contracts for review before writing.
# Falls back to terminal preview if neither is set.

EDITOR=
VISUAL=
